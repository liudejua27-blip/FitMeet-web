NODE_ENV=production
PORT=3000
BASE_URL=https://your-domain.example
FRONTEND_BASE_URL=https://your-domain.example
ALLOWED_ORIGINS=https://your-domain.example,https://www.your-domain.example
ADMIN_USER_IDS=1

DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=fitness_user
DB_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
DB_DATABASE=fitness_app
DB_MIGRATIONS_RUN=false
DB_SYNCHRONIZE=false

MONGO_USERNAME=fitness_mongo
MONGO_PASSWORD=CHANGE_ME_STRONG_MONGO_PASSWORD
MONGO_URI=mongodb://fitness_mongo:CHANGE_ME_STRONG_MONGO_PASSWORD@mongo:27017/fitness_app?authSource=admin

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

JWT_SECRET=CHANGE_ME_RANDOM_32_BYTE_HEX_SECRET
JWT_EXPIRES_IN=7d
HTTP_SLOW_REQUEST_MS=1000

KAFKA_BROKERS=kafka:29092
KAFKA_CLIENT_ID=fitness-app-prod

SMS_ACCESS_KEY=
SMS_SECRET_KEY=
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=https://your-domain.example/api/auth/wechat/callback
WECHAT_MINI_APP_ID=
WECHAT_MINI_APP_SECRET=

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=

ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_OSS_REGION=oss-cn-qingdao
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_ENDPOINT=https://oss-cn-qingdao.aliyuncs.com
ALIYUN_OSS_PUBLIC_BASE_URL=
ALIYUN_IMAGE_MODERATION_SERVICE=baselineCheck_global
ALIYUN_IMAGE_MODERATION_ENDPOINT=https://green-cip.ap-southeast-1.aliyuncs.com

AMAP_WEB_SERVICE_KEY=

VITE_API_BASE_URL=/api
VITE_WS_BASE_URL=
VITE_MAP_API_KEY=
VITE_AMAP_SECURITY_JS_CODE=
VITE_ICP_TEXT=
VITE_ICP_URL=http://beian.miit.gov.cn/

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
ENABLE_AI_SOCIAL_AUTOPILOT=false
AI_SOCIAL_AUTOPILOT_INTERVAL_MINUTES=5
ENABLE_SOCIAL_AGENT_AUTOPILOT=false
SOCIAL_AGENT_AUTOPILOT_INTERVAL_SECONDS=60
SOCIAL_AGENT_AUTOPILOT_MAX_TASKS_PER_RUN=20
ENABLE_PROFILE_MATCH_AUTOPILOT=true
PROFILE_MATCH_AUTOPILOT_INTERVAL_SECONDS=60
PROFILE_MATCH_AUTOPILOT_PER_OWNER_LIMIT=3
ENABLE_SUBCONSCIOUS_LOOP=false
SUBCONSCIOUS_LOOP_INTERVAL_SECONDS=60
SUBCONSCIOUS_LOOP_PER_OWNER_LIMIT=3
AGENT_WEBHOOK_SIGNING_SECRET=CHANGE_ME_RANDOM_WEBHOOK_SECRET
