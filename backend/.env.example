PORT=3000
BASE_URL=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:5173
ADMIN_USER_IDS=1

# Frontend origins allowed by CORS.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# PostgreSQL.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DB_DATABASE=fitness_app
DB_MIGRATIONS_RUN=false
DB_SYNCHRONIZE=true

# MongoDB.
MONGO_URI=mongodb://localhost:27017/fitness_app

# Redis.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# JWT.
# Production must use a strong random secret with at least 32 characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_USE_RANDOM_32_CHAR_SECRET_KEY
JWT_EXPIRES_IN=7d

# SMS service.
SMS_ACCESS_KEY=your-sms-access-key
SMS_SECRET_KEY=your-sms-secret-key

# WeChat login.
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret
WECHAT_REDIRECT_URI=http://localhost:3000/api/auth/wechat/callback
WECHAT_MINI_APP_ID=your-wechat-mini-program-app-id
WECHAT_MINI_APP_SECRET=CHANGE_ME_WECHAT_MINI_PROGRAM_SECRET

# Object storage.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_BUCKET_NAME=your-bucket-name

# Content moderation.
ALIYUN_ACCESS_KEY_ID=your-aliyun-access-key
ALIYUN_ACCESS_KEY_SECRET=your-aliyun-secret-key
ALIYUN_OSS_REGION=oss-cn-qingdao
ALIYUN_OSS_BUCKET=your-oss-bucket
ALIYUN_OSS_ENDPOINT=https://oss-cn-qingdao.aliyuncs.com
ALIYUN_OSS_PUBLIC_BASE_URL=https://your-oss-bucket.oss-cn-qingdao.aliyuncs.com
ALIYUN_IMAGE_MODERATION_SERVICE=baselineCheck_global
ALIYUN_IMAGE_MODERATION_ENDPOINT=https://green-cip.ap-southeast-1.aliyuncs.com

# Amap server API.
AMAP_WEB_SERVICE_KEY=your-amap-web-service-key

# Kafka. Disabled by default for local development; KafkaService runs in no-op mode.
ENABLE_KAFKA=false
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=fitness-app-dev

# AI service. Empty key keeps deterministic fallback enabled.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Agent social automation / enterprise webhooks.
ENABLE_AI_SOCIAL_AUTOPILOT=false
AI_SOCIAL_AUTOPILOT_INTERVAL_MINUTES=5

# FitMeet Subconscious Loop. Legacy PROFILE_MATCH_AUTOPILOT vars are still supported.
ENABLE_SUBCONSCIOUS_LOOP=true
SUBCONSCIOUS_LOOP_INTERVAL_SECONDS=60
SUBCONSCIOUS_LOOP_PER_OWNER_LIMIT=3
ENABLE_PROFILE_MATCH_AUTOPILOT=false
PROFILE_MATCH_AUTOPILOT_INTERVAL_SECONDS=60
PROFILE_MATCH_AUTOPILOT_PER_OWNER_LIMIT=3

AGENT_WEBHOOK_SIGNING_SECRET=CHANGE_ME_RANDOM_WEBHOOK_SECRET
