PORT=3000
BASE_URL=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:5173
ADMIN_USER_IDS=1

# Frontend origins allowed by CORS. Include both localhost and 127.0.0.1 because
# local dev servers and iOS/browser tooling may use either host spelling.
# ALLOWED_ORIGINS is preferred; CORS_ORIGIN can be used as an equivalent override.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# PostgreSQL. Managed hosts such as Railway can use DATABASE_URL instead of
# DB_HOST/DB_PORT/DB_USERNAME/DB_PASSWORD/DB_DATABASE.
DATABASE_URL=
DB_SSL=false
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=root
DB_PASSWORD=password123
DB_DATABASE=fitness_app
DB_POOL_MAX=30
DB_POOL_MIN=2
DB_MIGRATIONS_RUN=false
DB_SYNCHRONIZE=false

# MongoDB.
MONGO_URI=mongodb://localhost:27017/fitness_app

# Redis. Managed hosts such as Railway can use REDIS_URL instead of
# REDIS_HOST/REDIS_PORT/REDIS_PASSWORD.
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
# Local docker-compose Redis has no password. Production must set REDIS_URL or
# REDIS_PASSWORD through the deployment secret manager.
REDIS_PASSWORD=

# JWT.
# Production must use a strong random secret with at least 32 characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_USE_RANDOM_32_CHAR_SECRET_KEY
JWT_EXPIRES_IN=7d
HTTP_SLOW_REQUEST_MS=1000

# SMS service.
SMS_ACCESS_KEY=your-sms-access-key
SMS_SECRET_KEY=your-sms-secret-key

# WeChat login.
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret
WECHAT_REDIRECT_URI=http://localhost:3000/api/auth/wechat/callback
WECHAT_MINI_APP_ID=your-wechat-mini-program-app-id
WECHAT_MINI_APP_SECRET=CHANGE_ME_WECHAT_MINI_PROGRAM_SECRET

# Object storage.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_BUCKET_NAME=your-bucket-name
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=

# Content moderation.
ALIYUN_ACCESS_KEY_ID=your-aliyun-access-key
ALIYUN_ACCESS_KEY_SECRET=your-aliyun-secret-key
ALIYUN_OSS_REGION=oss-cn-qingdao
ALIYUN_OSS_BUCKET=your-oss-bucket
ALIYUN_OSS_ENDPOINT=https://oss-cn-qingdao.aliyuncs.com
ALIYUN_OSS_PUBLIC_BASE_URL=https://your-oss-bucket.oss-cn-qingdao.aliyuncs.com
ALIYUN_IMAGE_MODERATION_SERVICE=baselineCheck_global
ALIYUN_IMAGE_MODERATION_ENDPOINT=https://green-cip.ap-southeast-1.aliyuncs.com

# Amap server API.
AMAP_WEB_SERVICE_KEY=your-amap-web-service-key

# AI service. Empty key keeps deterministic fallback enabled for local tests.
# Production must set DEEPSEEK_API_KEY and explicit model ids; bare deepseek-v4
# and deepseek-chat are legacy aliases and should be replaced with deepseek-v4-pro
# or deepseek-v4-flash.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-v4-pro
DEEPSEEK_FAST_MODEL=deepseek-v4-flash
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_TIMEOUT_MS=30000
SOCIAL_AGENT_DEEPSEEK_TIMEOUT_MS=30000
SOCIAL_AGENT_DEEPSEEK_FIRST_CHUNK_TIMEOUT_MS=20000
SOCIAL_AGENT_MODEL_ROUTING_MODE=quality
SOCIAL_AGENT_INTENT_ROUTER_MODE=llm_first
SOCIAL_AGENT_INTENT_LLM=true
SOCIAL_AGENT_BRAIN_LLM_PLANNER=true
SOCIAL_AGENT_CONTEXT_TURN_LIMIT=80
SOCIAL_AGENT_CHAT_LLM_TIMEOUT_MS=30000
SOCIAL_AGENT_CHAT_FIRST_CHUNK_TIMEOUT_MS=20000
SOCIAL_AGENT_FINAL_RESPONSE_TIMEOUT_MS=30000
SOCIAL_AGENT_FINAL_RESPONSE_FIRST_CHUNK_TIMEOUT_MS=20000
SOCIAL_AGENT_FINAL_RESPONSE_MAX_TOKENS=1200
SOCIAL_AGENT_PLANNER_TIMEOUT_MS=25000
SOCIAL_AGENT_INTENT_TIMEOUT_MS=25000
SOCIAL_AGENT_DEEPSEEK_RETRY_ATTEMPTS=2
AGENT_CASUAL_CHAT_MODEL=
AGENT_FINAL_RESPONSE_MODEL=
AGENT_PLANNER_MODEL=
AGENT_EXTRACTOR_MODEL=
AGENT_CARD_MODEL=
AGENT_SAFETY_MODEL=

# Agent social automation / enterprise webhooks.
ENABLE_AI_SOCIAL_AUTOPILOT=false
AI_SOCIAL_AUTOPILOT_INTERVAL_MINUTES=5
ENABLE_SOCIAL_AGENT_AUTOPILOT=false
SOCIAL_AGENT_AUTOPILOT_INTERVAL_SECONDS=60
SOCIAL_AGENT_AUTOPILOT_MAX_TASKS_PER_RUN=20
AGENT_OBSERVABILITY_ALERTS_ENABLED=false
AGENT_OBSERVABILITY_ALERT_WEBHOOK_URL=
AGENT_OBSERVABILITY_ALERT_WEBHOOK_TOKEN=
AGENT_OBSERVABILITY_ALERT_COOLDOWN_MS=300000

# Independent subagent worker. Production should run npm run worker:subagent.
FITMEET_SUBAGENT_WORKER_MODE=db_queue
FITMEET_SUBAGENT_WORKER_CONCURRENCY=2
FITMEET_SUBAGENT_WORKER_POLL_MS=1000
FITMEET_SUBAGENT_WORKER_TIMEOUT_MS=30000
FITMEET_SUBAGENT_WORKER_QUEUE=fitmeet.subagent.agent-brain,fitmeet.subagent.life-graph-agent,fitmeet.subagent.match-agent

# FitMeet Profile Match Autopilot. Legacy SUBCONSCIOUS_LOOP vars are still supported.
ENABLE_PROFILE_MATCH_AUTOPILOT=true
PROFILE_MATCH_AUTOPILOT_INTERVAL_SECONDS=60
PROFILE_MATCH_AUTOPILOT_PER_OWNER_LIMIT=3
SOCIAL_AGENT_REMINDER_RUNNER_ENABLED=true
SOCIAL_AGENT_REMINDER_RUNNER_LIMIT=50
ENABLE_SUBCONSCIOUS_LOOP=false
SUBCONSCIOUS_LOOP_INTERVAL_SECONDS=60
SUBCONSCIOUS_LOOP_PER_OWNER_LIMIT=3

AGENT_WEBHOOK_SIGNING_SECRET=CHANGE_ME_RANDOM_WEBHOOK_SECRET
