{
  "name": "fitmeet-backend",
  "version": "0.0.1",
  "packageManager": "pnpm@10.30.3",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/database/data-source.ts --transaction each",
    "migration:run:prod": "typeorm -d dist/database/data-source.js migration:run --transaction each",
    "migration:status": "ts-node -r tsconfig-paths/register scripts/migration-status.ts",
    "agent:evaluate": "ts-node -r tsconfig-paths/register scripts/agent-evaluate.ts",
    "agent:replay": "ts-node -r tsconfig-paths/register scripts/agent-loop-replay.ts",
    "db:check-critical-tables:prod": "node dist/scripts/check-production-tables.js",
    "uploads:check:prod": "node dist/scripts/check-upload-dir.js",
    "seed:workout-candidates": "ts-node -r tsconfig-paths/register src/scripts/seed-workout-candidates.ts",
    "seed:workout-candidates:prod": "node dist/scripts/seed-workout-candidates.js",
    "seed:demand-candidates": "ts-node -r tsconfig-paths/register src/scripts/seed-demand-candidates.ts",
    "seed:demand-candidates:prod": "node dist/scripts/seed-demand-candidates.js",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate src/database/migrations/GeneratedMigration -d src/database/data-source.ts",
    "migration:create": "typeorm migration:create src/database/migrations/ManualMigration",
    "check:prod-env": "ts-node -r tsconfig-paths/register scripts/check-production-env.ts",
    "start": "nest start",
    "start:dev": "nest start --watch --entryFile main.js",
    "start:debug": "nest start --debug --watch --entryFile main.js",
    "start:prod": "node dist/main.js",
    "worker:subagent": "ts-node -r tsconfig-paths/register src/agent-gateway/subagent-worker.cli.ts",
    "worker:subagent:prod": "node dist/agent-gateway/subagent-worker.cli.js",
    "worker:subagent:healthcheck:prod": "node dist/agent-gateway/subagent-worker-healthcheck.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --max-warnings=0",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:agent-beta": "jest fitmeet-alpha-agent-sdk.service.spec.ts social-agent-brain.service.spec.ts social-agent-chat.service.spec.ts agent-quality-evaluator.service.spec.ts --runInBand",
    "test:agent-quality": "jest agent-quality-evaluator.service.spec.ts --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "pnpm run test:e2e:contract",
    "test:e2e:contract": "jest --config ./test/jest-e2e.json",
    "test:e2e:integration": "NODE_ENV=test ENABLE_SCHEDULER=false FITMEET_PROCESS_ROLE=api jest --config ./test/jest-e2e.integration.json --runInBand"
  },
  "dependencies": {
    "@alicloud/pop-core": "^1.8.0",
    "@aws-sdk/client-s3": "^3.1001.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.19",
    "@openai/agents": "^0.11.6",
    "@types/multer": "^2.0.0",
    "ali-oss": "^6.23.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "0.5",
    "class-validator": "^0.14.4",
    "compression": "^1.8.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "mongoose": "^8.23.0",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.19.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.28",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@types/ali-oss": "^6.23.3",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": "src/.*(\\.spec|\\.e2e-spec)\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coverageDirectory": "coverage",
    "testEnvironment": "node"
  }
}
