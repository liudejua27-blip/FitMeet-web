# FitMeet Agent remote smoke environment template.
#
# Copy this file to deploy/agent-smoke.remote.env on the ECS host or local
# operator machine, then fill only dedicated smoke/test credentials. The filled
# file is intentionally gitignored.
# Never use a real user account for mutating Agent smoke.

BASE_URL=https://www.ourfitmeet.cn
API_BASE_URL=https://www.ourfitmeet.cn/api
FITMEET_LAUNCH_TOPOLOGY=ecs

# Required for any smoke run that targets www.ourfitmeet.cn or another remote
# API. This makes accidental remote writes impossible unless explicitly enabled.
AGENT_SMOKE_ALLOW_REMOTE=true

# Readiness smoke still writes chat/search smoke data. Full smoke also exercises
# invitation/activity/review/Life Graph proposal paths with dedicated smoke data.
AGENT_SMOKE_ALLOW_MUTATIONS=true

# Use a dedicated smoke account. The preflight requires the email to look like a
# smoke/test/qa/e2e/staging account unless AGENT_SMOKE_ALLOW_NON_SMOKE_USER=true
# is intentionally set.
AGENT_SMOKE_EMAIL=agent-smoke-owner@ourfitmeet.cn
AGENT_SMOKE_PASSWORD=replace-with-dedicated-smoke-password

# Readiness mode should stop after OpportunityCards and before high-risk side
# effects. Full smoke can override this to false.
AGENT_SMOKE_STOP_AFTER_OPPORTUNITIES=true

# Optional pre-launch acceptance: adds a real 20-turn task-memory continuity
# scenario to prove the Agent keeps time/place/activity slots without repeating
# questions. Keep this off for quick smoke; enable before launch or after memory
# changes.
AGENT_SMOKE_RUN_20_TURN_MEMORY=false

# Optional pre-launch acceptance: proves an impossible real-candidate request
# renders CandidateEmptyStateCard with safe recovery actions instead of
# fabricating people. Keep this off for quick smoke; enable before launch or
# after candidate matching/fallback changes.
AGENT_SMOKE_RUN_EMPTY_CANDIDATE_FALLBACK=false
AGENT_SMOKE_EMPTY_CANDIDATE_MESSAGE=我想今天凌晨三点在火星奥林帕斯山附近找公开资料里有冰潜和舞蹈双标签的人一起散步，只用真实公开可发现候选；如果没有真实候选，请不要编造。

# Stable scenario knobs for the Agent opportunity journey.
AGENT_SMOKE_CITY=青岛
AGENT_SMOKE_ACTIVITY=咖啡轻聊天
AGENT_SMOKE_TIME=周末下午
AGENT_SMOKE_INTENSITY=轻松

# Required only when using --prepare-agent-smoke-seed or production seed writes.
AGENT_SMOKE_SEED_ALLOW_PRODUCTION=true

# Optional JWT mode. Leave disabled unless the token belongs to a dedicated smoke
# account and the run intentionally uses USER_JWT/FITMEET_USER_JWT.
AGENT_SMOKE_ALLOW_JWT_MUTATIONS=false
AGENT_SMOKE_ALLOW_NON_SMOKE_USER=false
