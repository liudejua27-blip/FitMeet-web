# FitMeet ECS production environment template.
# Copy this file to .env.production on the ECS host, then replace every
# CHANGE_ME value before running scripts/deploy-production.sh.

NODE_ENV=production
PORT=3000

# ECS same-origin topology:
# - nginx serves https://www.ourfitmeet.cn
# - nginx proxies https://www.ourfitmeet.cn/api to the backend container
BASE_URL=https://www.ourfitmeet.cn
FRONTEND_BASE_URL=https://www.ourfitmeet.cn
ALLOWED_ORIGINS=https://www.ourfitmeet.cn,https://ourfitmeet.cn
ADMIN_USER_IDS=1

# PostgreSQL container in docker-compose.prod.yml.
DATABASE_URL=
DB_SSL=false
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=fitness_user
DB_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
DB_DATABASE=fitness_app
DB_MIGRATIONS_RUN=false
DB_SYNCHRONIZE=false

# MongoDB container in docker-compose.prod.yml.
MONGO_USERNAME=fitness_mongo
MONGO_PASSWORD=CHANGE_ME_STRONG_MONGO_PASSWORD
MONGO_URI=mongodb://fitness_mongo:CHANGE_ME_STRONG_MONGO_PASSWORD@mongo:27017/fitness_app?authSource=admin

# Redis container in docker-compose.prod.yml.
REDIS_URL=
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# JWT and webhook signing secrets.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_RANDOM_32_BYTE_HEX_SECRET
JWT_EXPIRES_IN=7d
AGENT_WEBHOOK_SIGNING_SECRET=CHANGE_ME_RANDOM_WEBHOOK_SECRET
HTTP_SLOW_REQUEST_MS=1000

# Kafka container in docker-compose.prod.yml.
ENABLE_KAFKA=true
KAFKA_BROKERS=kafka:29092
KAFKA_CLIENT_ID=fitness-app-prod

# Optional SMS and WeChat login.
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=https://www.ourfitmeet.cn/api/auth/wechat/callback
WECHAT_MINI_APP_ID=
WECHAT_MINI_APP_SECRET=

# Upload storage. Production avatar/feed image flows need a real bucket.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=

ALIYUN_ACCESS_KEY_ID=CHANGE_ME_ALIYUN_ACCESS_KEY_ID
ALIYUN_ACCESS_KEY_SECRET=CHANGE_ME_ALIYUN_ACCESS_KEY_SECRET
ALIYUN_OSS_REGION=oss-cn-qingdao
ALIYUN_OSS_BUCKET=CHANGE_ME_OSS_BUCKET
ALIYUN_OSS_ENDPOINT=https://oss-cn-qingdao.aliyuncs.com
ALIYUN_OSS_PUBLIC_BASE_URL=https://CHANGE_ME_OSS_BUCKET.oss-cn-qingdao.aliyuncs.com
ALIYUN_IMAGE_MODERATION_SERVICE=baselineCheck_global
ALIYUN_IMAGE_MODERATION_ENDPOINT=https://green-cip.ap-southeast-1.aliyuncs.com

AMAP_WEB_SERVICE_KEY=

# Frontend build-time values. The uploaded ECS package is prebuilt with /api.
VITE_API_BASE_URL=/api
VITE_WS_BASE_URL=
VITE_MAP_API_KEY=
VITE_AMAP_SECURITY_JS_CODE=
VITE_ICP_TEXT=
VITE_ICP_URL=http://beian.miit.gov.cn/

# DeepSeek production models. Set a real API key before production use.
DEEPSEEK_API_KEY=CHANGE_ME_DEEPSEEK_API_KEY
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-v4-pro
DEEPSEEK_FAST_MODEL=deepseek-v4-flash
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_MS=12000
SOCIAL_AGENT_DEEPSEEK_TIMEOUT_MS=12000
AGENT_CASUAL_CHAT_MODEL=
AGENT_FINAL_RESPONSE_MODEL=
AGENT_PLANNER_MODEL=
AGENT_EXTRACTOR_MODEL=
AGENT_CARD_MODEL=
# Disabled for first launch. Set true and configure webhook/token when traffic grows.
AGENT_OBSERVABILITY_ALERTS_ENABLED=false
AGENT_OBSERVABILITY_ALERT_WEBHOOK_URL=
AGENT_OBSERVABILITY_ALERT_WEBHOOK_TOKEN=
AGENT_OBSERVABILITY_ALERT_COOLDOWN_MS=300000
FITMEET_SUBAGENT_WORKER_MODE=db_queue
FITMEET_SUBAGENT_WORKER_CONCURRENCY=2
FITMEET_SUBAGENT_WORKER_POLL_MS=1000
FITMEET_SUBAGENT_WORKER_TIMEOUT_MS=15000
FITMEET_SUBAGENT_WORKER_QUEUE=fitmeet.subagent.life-graph-agent,fitmeet.subagent.social-match-agent,fitmeet.subagent.meet-loop-agent,fitmeet.subagent.math-agent

ENABLE_AI_SOCIAL_AUTOPILOT=false
AI_SOCIAL_AUTOPILOT_INTERVAL_MINUTES=5
ENABLE_SOCIAL_AGENT_AUTOPILOT=false
SOCIAL_AGENT_AUTOPILOT_INTERVAL_SECONDS=60
SOCIAL_AGENT_AUTOPILOT_MAX_TASKS_PER_RUN=20
ENABLE_PROFILE_MATCH_AUTOPILOT=true
PROFILE_MATCH_AUTOPILOT_INTERVAL_SECONDS=60
PROFILE_MATCH_AUTOPILOT_PER_OWNER_LIMIT=3
ENABLE_SUBCONSCIOUS_LOOP=false
SUBCONSCIOUS_LOOP_INTERVAL_SECONDS=60
SUBCONSCIOUS_LOOP_PER_OWNER_LIMIT=3
