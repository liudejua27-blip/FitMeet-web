# FitMeet Railway backend environment template.
# Configure these variables on the Railway backend service. Do not commit real
# values. The Railway service root must be backend/ so backend/railway.json and
# backend/Dockerfile.prod are used as-is.

NODE_ENV=production
PORT=3000

BASE_URL=https://api.socialworld.world
FRONTEND_BASE_URL=https://socialworld.world
ALLOWED_ORIGINS=https://socialworld.world,https://www.socialworld.world
ADMIN_USER_IDS=1

# Prefer Railway managed service URLs for production.
DATABASE_URL=postgresql://CHANGE_ME
DB_SSL=true
DB_MIGRATIONS_RUN=false
DB_SYNCHRONIZE=false

MONGO_URI=mongodb://CHANGE_ME

REDIS_URL=redis://CHANGE_ME

JWT_SECRET=CHANGE_ME_RANDOM_32_BYTE_HEX_SECRET
JWT_EXPIRES_IN=7d
AGENT_WEBHOOK_SIGNING_SECRET=CHANGE_ME_RANDOM_WEBHOOK_SECRET
HTTP_SLOW_REQUEST_MS=1000

# Disable Kafka on Railway unless a managed Kafka endpoint is explicitly added.
ENABLE_KAFKA=false
KAFKA_BROKERS=
KAFKA_CLIENT_ID=fitness-app-prod

SMS_ACCESS_KEY=
SMS_SECRET_KEY=
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=https://api.socialworld.world/api/auth/wechat/callback
WECHAT_MINI_APP_ID=
WECHAT_MINI_APP_SECRET=

# Upload storage. Production avatar/feed image flows require OSS or S3.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=

ALIYUN_ACCESS_KEY_ID=CHANGE_ME_ALIYUN_ACCESS_KEY_ID
ALIYUN_ACCESS_KEY_SECRET=CHANGE_ME_ALIYUN_ACCESS_KEY_SECRET
ALIYUN_OSS_REGION=oss-cn-qingdao
ALIYUN_OSS_BUCKET=CHANGE_ME_OSS_BUCKET
ALIYUN_OSS_ENDPOINT=https://oss-cn-qingdao.aliyuncs.com
ALIYUN_OSS_PUBLIC_BASE_URL=https://CHANGE_ME_OSS_BUCKET.oss-cn-qingdao.aliyuncs.com
ALIYUN_IMAGE_MODERATION_SERVICE=baselineCheck_global
ALIYUN_IMAGE_MODERATION_ENDPOINT=https://green-cip.ap-southeast-1.aliyuncs.com

AMAP_WEB_SERVICE_KEY=

DEEPSEEK_API_KEY=CHANGE_ME_DEEPSEEK_API_KEY
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-v4-pro
DEEPSEEK_FAST_MODEL=deepseek-v4-flash
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_MS=12000
SOCIAL_AGENT_DEEPSEEK_TIMEOUT_MS=12000
AGENT_CASUAL_CHAT_MODEL=
AGENT_FINAL_RESPONSE_MODEL=
AGENT_PLANNER_MODEL=
AGENT_EXTRACTOR_MODEL=
AGENT_CARD_MODEL=
AGENT_OBSERVABILITY_ALERT_WEBHOOK_URL=CHANGE_ME_ALERT_WEBHOOK_URL
AGENT_OBSERVABILITY_ALERT_WEBHOOK_TOKEN=CHANGE_ME_ALERT_WEBHOOK_TOKEN
AGENT_OBSERVABILITY_ALERT_COOLDOWN_MS=300000

ENABLE_AI_SOCIAL_AUTOPILOT=false
AI_SOCIAL_AUTOPILOT_INTERVAL_MINUTES=5
ENABLE_SOCIAL_AGENT_AUTOPILOT=false
SOCIAL_AGENT_AUTOPILOT_INTERVAL_SECONDS=60
SOCIAL_AGENT_AUTOPILOT_MAX_TASKS_PER_RUN=20
ENABLE_PROFILE_MATCH_AUTOPILOT=true
PROFILE_MATCH_AUTOPILOT_INTERVAL_SECONDS=60
PROFILE_MATCH_AUTOPILOT_PER_OWNER_LIMIT=3
ENABLE_SUBCONSCIOUS_LOOP=false
SUBCONSCIOUS_LOOP_INTERVAL_SECONDS=60
SUBCONSCIOUS_LOOP_PER_OWNER_LIMIT=3
