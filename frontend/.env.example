# API
VITE_API_BASE_URL=http://localhost:3000/api
VITE_WS_BASE_URL=http://localhost:3000

# Agent adapter: production-grade QA should hit the real backend.
# Use "mock" only for explicit offline demos.
VITE_AGENT_ADAPTER=real

# Deprecated compatibility flag. Prefer VITE_AGENT_ADAPTER.
VITE_AGENT_MOCK_FLOW=false

# 可选: 地图/定位 API Key（约练页面）
VITE_MAP_API_KEY=
VITE_AMAP_SECURITY_JS_CODE=

# 可选: Sentry DSN（错误监控）
VITE_SENTRY_DSN=

# 网站备案信息
VITE_ICP_TEXT=鲁ICP备2026015946号-2
VITE_ICP_URL=http://beian.miit.gov.cn/
