{
  "name": "fitmeet-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "clean:dist": "node scripts/clean-dist.mjs",
    "generate:geo": "node scripts/generate-geo-static.mjs",
    "generate:og": "node scripts/generate-og-cover.mjs",
    "prebuild": "node scripts/generate-geo-static.mjs",
    "build": "pnpm run clean:dist && tsc -b && vite build && pnpm run check:prod-build",
    "build:lowmem": "pnpm run clean:dist && tsc -b && node --max-old-space-size=1024 ./node_modules/vite/bin/vite.js build && pnpm run check:prod-build",
    "check:prod-build": "node scripts/check-prod-build.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "ai": "^6.0.194",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "12.38.0",
    "gsap": "3.15.0",
    "lenis": "1.3.23",
    "lucide-react": "^1.17.0",
    "nanoid": "^5.1.11",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "react-virtuoso": "^4.18.6",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "three": "0.184.0",
    "use-stick-to-bottom": "^1.1.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.1",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.13",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "socket.io-parser": "4.2.6"
    }
  }
}
